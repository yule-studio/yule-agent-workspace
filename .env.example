# ─────────────────────────────────────────────────────────────────────────
# yule-agent-workspace — environment example
# Copy to .env (root) for the API/bot, and apps/web/.env.local for the web app.
# Everything has a local-dev default; the MVP runs with NO external services.
# ─────────────────────────────────────────────────────────────────────────

# ── API (apps/api) ──────────────────────────────────────────────────────
API_PORT=4319
API_HOST=127.0.0.1
# SQLite file path (relative to apps/api). Use :memory: for ephemeral runs.
WORKSPACE_DB_PATH=./data/workspace.db
# CORS origin allowed to call the API (the web app)
WEB_ORIGIN=http://localhost:3000

# ── Agent core adapter (link to yule-studio-agent) ──────────────────────
# mock  = run fully offline with canned transitions (default, no engine needed)
# http  = call a running yule-studio-agent HTTP bridge
AGENT_CORE_MODE=mock
AGENT_CORE_URL=http://127.0.0.1:8800
AGENT_CORE_TOKEN=

# ── Token / cost control defaults (overridable per role/session) ────────
# Daily ceiling across the whole workspace.
TOKEN_DAILY_CAP=2000000
# Default per-session budget when a task does not specify one.
TOKEN_SESSION_CAP=120000
# Fraction of the session budget at which we escalate to the operator.
TOKEN_ESCALATION_RATIO=0.8

# ── Discord bridge (apps/discord-bot) ────────────────────────────────────
# Leave DISCORD_TOKEN empty to run the bridge in mock mode (logs to stdout).
DISCORD_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ALERT_CHANNEL_ID=
# Where the bridge reads/writes canonical state.
WORKSPACE_API_URL=http://127.0.0.1:4319

# ── Web (apps/web/.env.local) ────────────────────────────────────────────
# Public base URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:4319
